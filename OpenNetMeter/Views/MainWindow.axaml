<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:vm="clr-namespace:OpenNetMeter.ViewModels"
        xmlns:tabs="clr-namespace:OpenNetMeter.Views.MainWindowTabs"
        x:Class="OpenNetMeter.Views.MainWindow"
        x:DataType="vm:MainWindowViewModel"
        Width="900"
        Height="600"
        MinWidth="800"
        MinHeight="500"
        Title="OpenNetMeter"
        Icon="avares://OpenNetMeter/Assets/x48.png"
        ExtendClientAreaToDecorationsHint="True"
        ExtendClientAreaChromeHints="NoChrome"
        ExtendClientAreaTitleBarHeightHint="0"
        SystemDecorations="None"
        Background="{DynamicResource BrushTransparent}"
        TransparencyLevelHint="None">
  <Design.DataContext>
    <vm:MainWindowViewModel/>
  </Design.DataContext>

  <Window.KeyBindings>
    <KeyBinding Gesture="Escape" Command="{Binding CloseAboutCommand}"/>
  </Window.KeyBindings>

  <Window.Resources>
    <ResourceDictionary>
      <ResourceDictionary.MergedDictionaries>
        <ResourceInclude Source="avares://OpenNetMeter/Views/Themes.axaml"/>
      </ResourceDictionary.MergedDictionaries>
    </ResourceDictionary>
  </Window.Resources>

  <Grid>
    <Border Background="{DynamicResource BrushBgWindow}" BorderBrush="{DynamicResource BrushBorderMain}" BorderThickness="1" CornerRadius="0">
      <Grid RowDefinitions="50,*,30">

        <Border Grid.Row="0" Background="{DynamicResource BrushBgTitleBar}" IsHitTestVisible="True">
          <Grid ColumnDefinitions="Auto,Auto,Auto,Auto,*,Auto,Auto,Auto">

            <Image Grid.Column="0" Source="avares://OpenNetMeter/Assets/x48.png"
                   Width="28" Height="28" Margin="14,0,0,0"
                   VerticalAlignment="Center"/>

            <Button Grid.Column="1" Content="Summary" Classes="tab"
                    Classes.active="{Binding IsSummaryTab}"
                    Command="{Binding SwitchTabCommand}" CommandParameter="0"
                    Margin="16,0,4,0"/>
            <Button Grid.Column="2" Content="History" Classes="tab"
                    Classes.active="{Binding IsHistoryTab}"
                    Command="{Binding SwitchTabCommand}" CommandParameter="1"
                    Margin="0,0,4,0"/>
            <Button Grid.Column="3" Content="Settings" Classes="tab"
                    Classes.active="{Binding IsSettingsTab}"
                    Command="{Binding SwitchTabCommand}" CommandParameter="2"/>

            <Border Grid.Column="4" Background="{DynamicResource BrushTransparent}" IsHitTestVisible="True"
                    PointerPressed="TitleBar_PointerPressed"/>

            <Button Grid.Column="5" Content="About" Classes="titleBtn"
                    Command="{Binding AboutCommand}"/>

            <Button Grid.Column="6" Classes="titleBtn" Command="{Binding MinimizeWindowCommand}">
              <Panel Width="10" Height="1">
                <Rectangle Fill="{DynamicResource BrushTextUi}" Height="1"/>
              </Panel>
            </Button>

            <Button Grid.Column="7" Classes="titleBtn closeBtn" Command="{Binding CloseWindowCommand}">
              <Panel Width="10" Height="10">
                <Line StartPoint="0,0" EndPoint="10,10" Stroke="{DynamicResource BrushTextUi}" StrokeThickness="1.2"/>
                <Line StartPoint="10,0" EndPoint="0,10" Stroke="{DynamicResource BrushTextUi}" StrokeThickness="1.2"/>
              </Panel>
            </Button>
          </Grid>
        </Border>

        <TabControl Grid.Row="1"
                    SelectedIndex="{Binding SelectedTabIndex, Mode=TwoWay}"
                    Margin="0"
                    Padding="0">
          <TabControl.Styles>
            <Style Selector="TabControl /template/ ItemsPresenter#PART_ItemsPresenter">
              <Setter Property="IsVisible" Value="False"/>
            </Style>
          </TabControl.Styles>

          <TabItem>
            <tabs:SummaryView DataContext="{Binding Summary}"/>
          </TabItem>

          <TabItem>
            <tabs:HistoryView DataContext="{Binding History}"/>
          </TabItem>

          <TabItem>
            <tabs:SettingsView DataContext="{Binding Settings}"/>
          </TabItem>
        </TabControl>

        <Border Grid.Row="2" Background="{DynamicResource BrushBgTitleBar}" BorderBrush="{DynamicResource BrushBorderMain}" BorderThickness="0,1,0,0">
          <Grid ColumnDefinitions="*,Auto,Auto,Auto,Auto" Margin="10,0">
            <TextBlock Grid.Column="0" Text="{Binding NetworkStatus}" FontSize="12"
                       Foreground="{DynamicResource BrushTextUi}" VerticalAlignment="Center"/>

            <TextBlock Grid.Column="1" Text="Download Speed :" FontSize="12"
                       Foreground="{DynamicResource BrushTextSecondaryAlt}" VerticalAlignment="Center" Margin="0,0,4,0"/>
            <TextBlock Grid.Column="2" FontSize="12" Foreground="{DynamicResource BrushTextUi}"
                       VerticalAlignment="Center" Margin="0,0,16,0"
                       Text="{Binding Summary.DownloadSpeedText}"/>

            <TextBlock Grid.Column="3" Text="Upload Speed :" FontSize="12"
                       Foreground="{DynamicResource BrushTextSecondaryAlt}" VerticalAlignment="Center" Margin="0,0,4,0"/>
            <TextBlock Grid.Column="4" FontSize="12" Foreground="{DynamicResource BrushTextUi}"
                       VerticalAlignment="Center"
                       Text="{Binding Summary.UploadSpeedText}"/>
          </Grid>
        </Border>
      </Grid>
    </Border>

    <Border HorizontalAlignment="Stretch" VerticalAlignment="Top" Height="6" Background="{DynamicResource BrushTransparent}"
            Cursor="SizeNorthSouth" PointerPressed="ResizeTop_PointerPressed"/>
    <Border HorizontalAlignment="Stretch" VerticalAlignment="Bottom" Height="6" Background="{DynamicResource BrushTransparent}"
            Cursor="SizeNorthSouth" PointerPressed="ResizeBottom_PointerPressed"/>
    <Border HorizontalAlignment="Left" VerticalAlignment="Stretch" Width="6" Background="{DynamicResource BrushTransparent}"
            Cursor="SizeWestEast" PointerPressed="ResizeLeft_PointerPressed"/>
    <Border HorizontalAlignment="Right" VerticalAlignment="Stretch" Width="6" Background="{DynamicResource BrushTransparent}"
            Cursor="SizeWestEast" PointerPressed="ResizeRight_PointerPressed"/>

    <Border HorizontalAlignment="Left" VerticalAlignment="Top" Width="10" Height="10" Background="{DynamicResource BrushTransparent}"
            Cursor="TopLeftCorner" PointerPressed="ResizeTopLeft_PointerPressed"/>
    <Border HorizontalAlignment="Right" VerticalAlignment="Top" Width="10" Height="10" Background="{DynamicResource BrushTransparent}"
            Cursor="TopRightCorner" PointerPressed="ResizeTopRight_PointerPressed"/>
    <Border HorizontalAlignment="Left" VerticalAlignment="Bottom" Width="10" Height="10" Background="{DynamicResource BrushTransparent}"
            Cursor="BottomLeftCorner" PointerPressed="ResizeBottomLeft_PointerPressed"/>
    <Border HorizontalAlignment="Right" VerticalAlignment="Bottom" Width="10" Height="10" Background="{DynamicResource BrushTransparent}"
            Cursor="BottomRightCorner" PointerPressed="ResizeBottomRight_PointerPressed"/>

    <Border IsVisible="{Binding IsAboutOpen}"
            Background="{DynamicResource BrushOverlayScrim}">
      <Grid>
        <Border Width="360" HorizontalAlignment="Center" VerticalAlignment="Center"
                BorderBrush="{DynamicResource BrushBorderMain}" BorderThickness="1"
                Background="{DynamicResource BrushBgWindow}">
          <Grid RowDefinitions="Auto,*">

            <Border Grid.Row="0" Background="{DynamicResource BrushBgTitleBar}">
              <Grid ColumnDefinitions="*,Auto" Margin="12,0,0,10">
                <StackPanel Grid.Column="0" Margin="0,10,0,0" Orientation="Horizontal" HorizontalAlignment="Center" VerticalAlignment="Center" Spacing="10">
                  <Image Source="avares://OpenNetMeter/Assets/x48.png"
                         Width="48" Height="48"/>
                  <TextBlock Text="OpenNetMeter" FontSize="30" FontWeight="Bold"
                             Foreground="{DynamicResource BrushTextPrimary}"/>
                </StackPanel>

                <Button Grid.Column="1" Classes="titleBtn closeBtn" HorizontalAlignment="Right" Command="{Binding CloseAboutCommand}">
                  <Panel Width="10" Height="10">
                    <Line StartPoint="0,0" EndPoint="10,10" Stroke="{DynamicResource BrushTextUi}" StrokeThickness="1.2"/>
                    <Line StartPoint="10,0" EndPoint="0,10" Stroke="{DynamicResource BrushTextUi}" StrokeThickness="1.2"/>
                  </Panel>
                </Button>
              </Grid>
            </Border>

            <Border Grid.Row="1" Background="{DynamicResource BrushBgSubtle}" Padding="10">
              <Border BorderBrush="{DynamicResource BrushBorderSubtle}" BorderThickness="1"
                      Background="{DynamicResource BrushBgSurface}" Padding="12">
                <StackPanel Spacing="10">
                  <TextBlock Text="{Binding AboutVersionText}"
                             FontSize="{DynamicResource FontSizeMd}"
                             Foreground="{DynamicResource BrushTextPrimary}"/>
                  <TextBlock TextWrapping="Wrap"
                             Text="This product is created and maintained by Ashfaaq Riphque."
                             Foreground="{DynamicResource BrushTextPrimary}"/>
                  <TextBlock TextWrapping="Wrap"
                             Text="If you find any problems with the product or have ideas for improvements, feel free to create an issue at:"
                             Foreground="{DynamicResource BrushTextPrimary}"/>
                  <Button Classes="linkBtn"
                          Command="{Binding OpenAboutRepositoryCommand}"
                          HorizontalAlignment="Left">
                    <TextBlock Text="{Binding AboutRepositoryUrl}"
                               Foreground="{DynamicResource BrushLink}"
                               TextDecorations="Underline"/>
                  </Button>
                </StackPanel>
              </Border>
            </Border>

          </Grid>
        </Border>
      </Grid>
    </Border>

    <Border IsVisible="{Binding Settings.IsDeleteConfirmationOpen}"
            Background="{DynamicResource BrushOverlayScrim}">
      <Grid>
        <Border Width="360" HorizontalAlignment="Center" VerticalAlignment="Center"
                BorderBrush="{DynamicResource BrushBorderMain}" BorderThickness="1"
                Background="{DynamicResource BrushBgWindow}">
          <Grid RowDefinitions="Auto,*">

            <Border Grid.Row="0" Background="{DynamicResource BrushBgTitleBar}">
              <Grid ColumnDefinitions="*,Auto">
                <TextBlock Grid.Column="0" Text="Confirm" VerticalAlignment="Center"
                           Margin="15,0" Foreground="{DynamicResource BrushTextPrimary}"/>

                <Button Grid.Column="1" Classes="titleBtn closeBtn" HorizontalAlignment="Right"
                        Command="{Binding Settings.CancelDeleteAllDataCommand}">
                  <Panel Width="10" Height="10">
                    <Line StartPoint="0,0" EndPoint="10,10" Stroke="{DynamicResource BrushTextUi}" StrokeThickness="1.2"/>
                    <Line StartPoint="10,0" EndPoint="0,10" Stroke="{DynamicResource BrushTextUi}" StrokeThickness="1.2"/>
                  </Panel>
                </Button>
              </Grid>
            </Border>

            <Border Grid.Row="1" Background="{DynamicResource BrushBgSubtle}" Padding="20,10,20,20">
              <StackPanel Spacing="20">
                <TextBlock Text="{Binding Settings.DeleteConfirmationMessage}"
                           Foreground="{DynamicResource BrushTextPrimary}"
                           TextWrapping="Wrap"/>

                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Spacing="20">
                  <Button MinWidth="60" Padding="16,8" Command="{Binding Settings.ConfirmDeleteAllDataCommand}">
                    <TextBlock Text="Yes" HorizontalAlignment="Center"/>
                  </Button>
                  <Button MinWidth="60" Padding="16,8" Command="{Binding Settings.CancelDeleteAllDataCommand}">
                    <TextBlock Text="No" HorizontalAlignment="Center"/>
                  </Button>
                </StackPanel>
              </StackPanel>
            </Border>

          </Grid>
        </Border>
      </Grid>
    </Border>
  </Grid>

  <Window.Styles>
    <Style Selector="TextBlock">
      <Setter Property="FontSize" Value="{DynamicResource FontSizeSm}"/>
      <Setter Property="Foreground" Value="{DynamicResource BrushTextPrimary}"/>
    </Style>
    <Style Selector="Button">
      <Setter Property="FontSize" Value="{DynamicResource FontSizeSm}"/>
    </Style>
    <Style Selector="ComboBox">
      <Setter Property="FontSize" Value="{DynamicResource FontSizeSm}"/>
    </Style>
    <Style Selector="DatePicker">
      <Setter Property="FontSize" Value="{DynamicResource FontSizeSm}" />
      <Setter Property="Padding" Value="2" />
    </Style>

    <Style Selector="Button.tab">
      <Setter Property="Background" Value="{DynamicResource BrushTransparent}"/>
      <Setter Property="Foreground" Value="{DynamicResource BrushTextSecondary}"/>
      <Setter Property="FontSize" Value="{DynamicResource FontSizeLg}"/>
      <Setter Property="Padding" Value="12,6"/>
      <Setter Property="BorderThickness" Value="0,0,0,3"/>
      <Setter Property="BorderBrush" Value="{DynamicResource BrushTransparent}"/>
      <Setter Property="VerticalAlignment" Value="Bottom"/>
      <Setter Property="Height" Value="40"/>
      <Setter Property="CornerRadius" Value="0"/>
    </Style>
    <Style Selector="Button.tab /template/ ContentPresenter">
      <Setter Property="BorderThickness" Value="0,0,0,3"/>
      <Setter Property="BorderBrush" Value="{DynamicResource BrushTransparent}"/>
    </Style>
    <Style Selector="Button.tab:pointerover /template/ ContentPresenter">
      <Setter Property="Background" Value="{DynamicResource BrushBgSurfaceHover}"/>
      <Setter Property="Foreground" Value="{DynamicResource BrushTextPrimary}"/>
    </Style>
    <Style Selector="Button.tab.active">
      <Setter Property="Foreground" Value="{DynamicResource BrushWhite}"/>
      <Setter Property="BorderBrush" Value="{DynamicResource BrushAccentGreen}"/>
    </Style>
    <Style Selector="Button.tab.active /template/ ContentPresenter">
      <Setter Property="Foreground" Value="{DynamicResource BrushWhite}"/>
      <Setter Property="BorderBrush" Value="{DynamicResource BrushAccentGreen}"/>
    </Style>

    <Style Selector="Button.titleBtn">
      <Setter Property="Background" Value="{DynamicResource BrushTransparent}"/>
      <Setter Property="Foreground" Value="{DynamicResource BrushTextPrimary}"/>
      <Setter Property="Width" Value="50"/>
      <Setter Property="Height" Value="32"/>
      <Setter Property="VerticalAlignment" Value="Top"/>
      <Setter Property="HorizontalContentAlignment" Value="Center"/>
      <Setter Property="VerticalContentAlignment" Value="Center"/>
      <Setter Property="BorderThickness" Value="0"/>
      <Setter Property="Padding" Value="0"/>
      <Setter Property="CornerRadius" Value="0"/>
    </Style>
    <Style Selector="Button.titleBtn:pointerover /template/ ContentPresenter">
      <Setter Property="Background" Value="{DynamicResource BrushBgSurfaceHover}"/>
    </Style>
    <Style Selector="Button.closeBtn:pointerover /template/ ContentPresenter">
      <Setter Property="Background" Value="{DynamicResource BrushDanger}"/>
    </Style>
    <Style Selector="Button.linkBtn">
      <Setter Property="Background" Value="{DynamicResource BrushTransparent}"/>
      <Setter Property="BorderThickness" Value="0"/>
      <Setter Property="Padding" Value="0"/>
      <Setter Property="CornerRadius" Value="0"/>
      <Setter Property="HorizontalContentAlignment" Value="Left"/>
    </Style>
    <Style Selector="Button.linkBtn:pointerover /template/ ContentPresenter">
      <Setter Property="Background" Value="{DynamicResource BrushTransparent}"/>
      <Setter Property="Opacity" Value="0.85"/>
    </Style>
    <Style Selector="DatePickerPresenter">
      <Setter Property="MinWidth" Value="0" />
      <Setter Property="Width" Value="140" />
    </Style>
    <Style Selector="DatePickerPresenter /template/ DateTimePickerPanel > ListBoxItem">
      <Setter Property="FontSize" Value="{DynamicResource FontSizeSm}" />
      <Setter Property="Padding" Value="2,0" />
    </Style>

    <Style Selector="RadioButton.pill">
      <Setter Property="Background" Value="{DynamicResource BrushBgSubtle}"/>
      <Setter Property="Foreground" Value="{DynamicResource BrushTextSecondary}"/>
      <Setter Property="CornerRadius" Value="6"/>
      <Setter Property="Padding" Value="16,8"/>
      <Setter Property="BorderBrush" Value="{DynamicResource BrushBorderSubtle}"/>
      <Setter Property="BorderThickness" Value="1"/>
      <Setter Property="Cursor" Value="Hand"/>
      <Setter Property="Template">
        <ControlTemplate>
          <Border Background="{TemplateBinding Background}"
                  BorderBrush="{TemplateBinding BorderBrush}"
                  BorderThickness="{TemplateBinding BorderThickness}"
                  CornerRadius="{TemplateBinding CornerRadius}"
                  Padding="{TemplateBinding Padding}">
            <ContentPresenter Content="{TemplateBinding Content}"
                              HorizontalAlignment="Center"/>
          </Border>
        </ControlTemplate>
      </Setter>
    </Style>
    <Style Selector="RadioButton.pill:pointerover">
      <Setter Property="Background" Value="{DynamicResource BrushBorderMain}"/>
      <Setter Property="BorderBrush" Value="{DynamicResource BrushAccentBlue}"/>
    </Style>
    <Style Selector="RadioButton.pill:checked">
      <Setter Property="Background" Value="{DynamicResource BrushPillCheckedBg}"/>
      <Setter Property="BorderBrush" Value="{DynamicResource BrushAccentBlue}"/>
      <Setter Property="Foreground" Value="{DynamicResource BrushAccentBlue}"/>
    </Style>
    <Style Selector="RadioButton.pill:checked /template/ ContentPresenter">
      <Setter Property="Foreground" Value="{DynamicResource BrushAccentBlue}"/>
    </Style>
  </Window.Styles>
</Window>
