<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:vm="clr-namespace:OpenNetMeter.ViewModels"
        x:Class="OpenNetMeter.Views.MiniWidgetWindow"
        x:DataType="vm:MiniWidgetViewModel"
        Width="260"
        Height="44"
        CanResize="False"
        SystemDecorations="None"
        ShowInTaskbar="False"
        Topmost="True"
        Background="Transparent"
        TransparencyLevelHint="Transparent">
  <Design.DataContext>
    <vm:MiniWidgetViewModel />
  </Design.DataContext>

  <Window.Resources>
    <SolidColorBrush x:Key="BrushWidgetBorder" Color="#616161"/>
    <SolidColorBrush x:Key="BrushWidgetText" Color="#F0F0F0"/>
    <SolidColorBrush x:Key="BrushWidgetTextMuted" Color="#C8C8C8"/>
    <SolidColorBrush x:Key="BrushDownloadBadge" Color="#367061"/>
    <SolidColorBrush x:Key="BrushUploadBadge" Color="#D98868"/>
    <SolidColorBrush x:Key="BrushPinHover" Color="#1AFFFFFF"/>
    <SolidColorBrush x:Key="BrushPinActive" Color="#261A3A5C"/>
  </Window.Resources>
  <Window.Styles>
    <Style Selector="TextBlock.speedValue">
      <Setter Property="FontSize" Value="11"/>
      <Setter Property="FontWeight" Value="SemiBold"/>
      <Setter Property="Foreground" Value="{DynamicResource BrushWidgetText}"/>
      <Setter Property="VerticalAlignment" Value="Center"/>
    </Style>
    <Style Selector="TextBlock.totalLabel">
      <Setter Property="FontSize" Value="10"/>
      <Setter Property="FontWeight" Value="SemiBold"/>
      <Setter Property="VerticalAlignment" Value="Center"/>
    </Style>
    <Style Selector="TextBlock.totalValue">
      <Setter Property="FontSize" Value="10"/>
      <Setter Property="Foreground" Value="{DynamicResource BrushWidgetTextMuted}"/>
      <Setter Property="VerticalAlignment" Value="Center"/>
    </Style>
    <Style Selector="ToggleButton.pinButton">
      <Setter Property="Width" Value="18"/>
      <Setter Property="Height" Value="18"/>
      <Setter Property="Background" Value="Transparent"/>
      <Setter Property="BorderBrush" Value="{DynamicResource BrushWidgetText}"/>
      <Setter Property="BorderThickness" Value="1"/>
      <Setter Property="CornerRadius" Value="2"/>
      <Setter Property="Padding" Value="1"/>
    </Style>
    <Style Selector="ToggleButton.pinButton:pointerover">
      <Setter Property="Background" Value="{DynamicResource BrushPinHover}"/>
    </Style>
    <Style Selector="ToggleButton.pinButton:checked">
      <Setter Property="Background" Value="{DynamicResource BrushPinActive}"/>
    </Style>
  </Window.Styles>

  <Border Margin="1"
          CornerRadius="0"
          BorderThickness="1"
          BorderBrush="{DynamicResource BrushWidgetBorder}"
          Background="{Binding BackgroundColor}"
          Padding="4,2"
          PointerPressed="WidgetChrome_PointerPressed">
    <Border.ContextMenu>
      <ContextMenu>
        <MenuItem Header="Open"
                  Command="{Binding OpenMainWindowCommand}"/>
        <MenuItem Header="Hide"
                  Command="{Binding HideWidgetCommand}"/>
      </ContextMenu>
    </Border.ContextMenu>

    <Grid ColumnDefinitions="*,*,Auto">
      <StackPanel Grid.Column="0"
                  Orientation="Horizontal"
                  Spacing="6"
                  Margin="0,0,8,0"
                  VerticalAlignment="Center">
        <Border Width="20"
                Height="24"
                Background="{DynamicResource BrushDownloadBadge}"
                CornerRadius="4"
                VerticalAlignment="Center">
          <TextBlock Text="↓"
                     FontSize="16"
                     FontWeight="Bold"
                     Foreground="White"
                     HorizontalAlignment="Center"
                     VerticalAlignment="Center"/>
        </Border>
        <StackPanel Spacing="1"
                    VerticalAlignment="Center">
          <TextBlock Classes="speedValue"
                     Text="{Binding DownloadSpeedText}"/>
          <StackPanel Orientation="Horizontal"
                      Spacing="3">
            <TextBlock Classes="totalLabel"
                       Text="Total:"
                       Foreground="{DynamicResource BrushDownloadBadge}"/>
            <TextBlock Classes="totalValue"
                       Text="{Binding CurrentSessionDownloadText}"/>
          </StackPanel>
        </StackPanel>
      </StackPanel>

      <StackPanel Grid.Column="1"
                  Orientation="Horizontal"
                  Spacing="6"
                  Margin="0,0,8,0"
                  VerticalAlignment="Center">
        <Border Width="20"
                Height="24"
                Background="{DynamicResource BrushUploadBadge}"
                CornerRadius="4"
                VerticalAlignment="Center">
          <TextBlock Text="↑"
                     FontSize="16"
                     FontWeight="Bold"
                     Foreground="White"
                     HorizontalAlignment="Center"
                     VerticalAlignment="Center"/>
        </Border>
        <StackPanel Spacing="1"
                    VerticalAlignment="Center">
          <TextBlock Classes="speedValue"
                     Text="{Binding UploadSpeedText}"/>
          <StackPanel Orientation="Horizontal"
                      Spacing="3">
            <TextBlock Classes="totalLabel"
                       Text="Total:"
                       Foreground="{DynamicResource BrushUploadBadge}"/>
            <TextBlock Classes="totalValue"
                       Text="{Binding CurrentSessionUploadText}"/>
          </StackPanel>
        </StackPanel>
      </StackPanel>

      <ToggleButton Grid.Column="2"
                    Classes="pinButton"
                    Margin="2,0,0,0"
                    HorizontalAlignment="Right"
                    VerticalAlignment="Top"
                    IsChecked="{Binding IsPinned, Mode=TwoWay}"
                    ToolTip.Tip="{Binding PinToolTip}">
        <Image Source="{Binding PinIconSource}"
               Width="12"
               Height="12"/>
      </ToggleButton>
    </Grid>
  </Border>
</Window>
