<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:vm="clr-namespace:OpenNetMeter.ViewModels"
             xmlns:lvc="using:LiveChartsCore.SkiaSharpView.Avalonia"
             x:Class="OpenNetMeter.Views.MainWindowTabs.SummaryView"
             x:DataType="vm:SummaryViewModel"
             mc:Ignorable="d">
  <Grid Margin="12,8" RowDefinitions="*,110" ColumnDefinitions="180,12,*">
    <Grid Grid.Row="0" Grid.Column="0" RowDefinitions="Auto,10,Auto,10,*">
      <Border Grid.Row="0" Padding="10" CornerRadius="12" Background="{DynamicResource BrushSurfacePanel}" BoxShadow="{DynamicResource ShadowStrong}">
        <StackPanel Spacing="4">
          <StackPanel Orientation="Horizontal" Margin="0,0,0,6">
            <Border CornerRadius="6" Padding="4" Width="22" Height="22" Background="{DynamicResource BrushSuccess}">
              <PathIcon Data="M12,2A10,10 0 0,0 2,12A10,10 0 0,0 12,22A10,10 0 0,0 22,12A10,10 0 0,0 12,2M12.5,7V12.25L17,14.92L16.25,16.15L11,13V7H12.5Z"
                        Foreground="{DynamicResource BrushWhite}" Width="12" Height="12"/>
            </Border>
            <TextBlock Text="Current Session" FontSize="11" FontWeight="SemiBold"
                       Foreground="{DynamicResource BrushTextHeader}" VerticalAlignment="Center" Margin="6,0,0,0"/>
          </StackPanel>

          <Border CornerRadius="6" Padding="8,4" Background="{DynamicResource BrushSuccess}" Margin="0,0,0,4">
            <Grid ColumnDefinitions="Auto,*">
              <StackPanel Orientation="Horizontal">
                <PathIcon Data="M5,20H19V18H5M19,9H15V3H9V9H5L12,16L19,9Z"
                          Foreground="{DynamicResource BrushWhite}" Width="12" Height="12"/>
                <TextBlock Text="DL" Foreground="{DynamicResource BrushWhite}" FontSize="10" VerticalAlignment="Center" Margin="4,0,0,0"/>
              </StackPanel>
              <TextBlock Grid.Column="1" Text="{Binding CurrentSessionDownloadText}"
                         Foreground="{DynamicResource BrushWhite}" FontSize="11" FontWeight="SemiBold"
                         HorizontalAlignment="Right" VerticalAlignment="Center"/>
            </Grid>
          </Border>

          <Border CornerRadius="6" Padding="8,4" Background="{DynamicResource BrushInfo}">
            <Grid ColumnDefinitions="Auto,*">
              <StackPanel Orientation="Horizontal">
                <PathIcon Data="M9,16V10H5L12,3L19,10H15V16H9M5,20V18H19V20H5Z"
                          Foreground="{DynamicResource BrushWhite}" Width="12" Height="12"/>
                <TextBlock Text="UL" Foreground="{DynamicResource BrushWhite}" FontSize="10" VerticalAlignment="Center" Margin="4,0,0,0"/>
              </StackPanel>
              <TextBlock Grid.Column="1" Text="{Binding CurrentSessionUploadText}"
                         Foreground="{DynamicResource BrushWhite}" FontSize="11" FontWeight="SemiBold"
                         HorizontalAlignment="Right" VerticalAlignment="Center"/>
            </Grid>
          </Border>
        </StackPanel>
      </Border>

      <Border Grid.Row="2" Padding="10" CornerRadius="12" Background="{DynamicResource BrushSurfacePanel}" BoxShadow="{DynamicResource ShadowStrong}">
        <StackPanel Spacing="4">
          <StackPanel Orientation="Horizontal" Margin="0,0,0,6">
            <Border CornerRadius="6" Padding="4" Width="22" Height="22" Background="{DynamicResource BrushInfo}">
              <PathIcon Data="M12,3C7.58,3 4,4.79 4,7C4,9.21 7.58,11 12,11C16.42,11 20,9.21 20,7C20,4.79 16.42,3 12,3M4,9V12C4,14.21 7.58,16 12,16C16.42,16 20,14.21 20,12V9C20,11.21 16.42,13 12,13C7.58,13 4,11.21 4,9M4,14V17C4,19.21 7.58,21 12,21C16.42,21 20,19.21 20,17V14C20,16.21 16.42,18 12,18C7.58,18 4,16.21 4,14Z"
                        Foreground="{DynamicResource BrushWhite}" Width="12" Height="12"/>
            </Border>
            <TextBlock Text="Usage From" FontSize="11" FontWeight="SemiBold"
                       Foreground="{DynamicResource BrushTextHeader}" VerticalAlignment="Center" Margin="6,0,0,0"/>
          </StackPanel>

          <DatePicker MinWidth="0" Width="140" Height="30" HorizontalAlignment="Stretch" VerticalAlignment="Center" Margin="0,0,0,6"
                      SelectedDate="{Binding SinceDate, Mode=TwoWay}"/>

          <Border CornerRadius="6" Padding="8,4" Background="{DynamicResource BrushSuccess}" Margin="0,0,0,4">
            <Grid ColumnDefinitions="Auto,*">
              <StackPanel Orientation="Horizontal">
                <PathIcon Data="M5,20H19V18H5M19,9H15V3H9V9H5L12,16L19,9Z"
                          Foreground="{DynamicResource BrushWhite}" Width="12" Height="12"/>
                <TextBlock Text="DL" Foreground="{DynamicResource BrushWhite}" FontSize="10" VerticalAlignment="Center" Margin="4,0,0,0"/>
              </StackPanel>
              <TextBlock Grid.Column="1" Text="{Binding TotalFromDateDownloadText}"
                         Foreground="{DynamicResource BrushWhite}" FontSize="11" FontWeight="SemiBold"
                         HorizontalAlignment="Right" VerticalAlignment="Center"/>
            </Grid>
          </Border>

          <Border CornerRadius="6" Padding="8,4" Background="{DynamicResource BrushInfo}">
            <Grid ColumnDefinitions="Auto,*">
              <StackPanel Orientation="Horizontal">
                <PathIcon Data="M9,16V10H5L12,3L19,10H15V16H9M5,20V18H19V20H5Z"
                          Foreground="{DynamicResource BrushWhite}" Width="12" Height="12"/>
                <TextBlock Text="UL" Foreground="{DynamicResource BrushWhite}" FontSize="10" VerticalAlignment="Center" Margin="4,0,0,0"/>
              </StackPanel>
              <TextBlock Grid.Column="1" Text="{Binding TotalFromDateUploadText}"
                         Foreground="{DynamicResource BrushWhite}" FontSize="11" FontWeight="SemiBold"
                         HorizontalAlignment="Right" VerticalAlignment="Center"/>
            </Grid>
          </Border>
        </StackPanel>
      </Border>

      <Border Grid.Row="4" Padding="10" CornerRadius="12,12,0,0" Background="{DynamicResource BrushSurfacePanel}"
              BoxShadow="{DynamicResource ShadowStrong}" VerticalAlignment="Bottom">
        <StackPanel>
          <StackPanel Orientation="Horizontal">
            <Border CornerRadius="6" Padding="4" Width="22" Height="22" Background="{DynamicResource BrushSuccess}">
              <PathIcon Data="M22,21H2V3H4V19H6V10H10V19H12V6H16V19H18V14H22V21Z"
                        Foreground="{DynamicResource BrushWhite}" Width="12" Height="12"/>
            </Border>
            <TextBlock Text="Activity" FontSize="11" FontWeight="SemiBold"
                       Foreground="{DynamicResource BrushTextHeader}" VerticalAlignment="Center" Margin="6,0,0,0"/>
          </StackPanel>
          <StackPanel Orientation="Horizontal" Margin="0,8,0,0">
            <Ellipse Width="8" Height="8" Fill="{DynamicResource BrushSuccess}" VerticalAlignment="Center"/>
            <TextBlock Text="Download" Foreground="{DynamicResource BrushTextSecondaryAlt}" FontSize="10" Margin="4,0,12,0" VerticalAlignment="Center"/>
            <Ellipse Width="8" Height="8" Fill="{DynamicResource BrushInfo}" VerticalAlignment="Center"/>
            <TextBlock Text="Upload" Foreground="{DynamicResource BrushTextSecondaryAlt}" FontSize="10" Margin="4,0,0,0" VerticalAlignment="Center"/>
          </StackPanel>
        </StackPanel>
      </Border>
    </Grid>

    <Border Grid.Row="0" Grid.Column="2" CornerRadius="12" Background="{DynamicResource BrushSurfacePanel}"
            BoxShadow="{DynamicResource ShadowStrong}" Margin="0,0,0,10" Padding="0" ClipToBounds="True">
      <Grid RowDefinitions="Auto,*">
        <Border Grid.Row="0" Padding="12,8" Background="{DynamicResource BrushHeaderRow}"
                BorderBrush="{DynamicResource BrushBorderEmphasis}" BorderThickness="0,0,0,1">
          <Grid>
            <StackPanel Orientation="Horizontal">
              <PathIcon Data="M12,2A2,2 0 0,1 14,4C14,4.74 13.6,5.39 13,5.73V7H14A7,7 0 0,1 21,14H22A1,1 0 0,1 23,15V18A1,1 0 0,1 22,19H21V20A2,2 0 0,1 19,22H5A2,2 0 0,1 3,20V19H2A1,1 0 0,1 1,18V15A1,1 0 0,1 2,14H3A7,7 0 0,1 10,7H11V5.73C10.4,5.39 10,4.74 10,4A2,2 0 0,1 12,2M7.5,13A2.5,2.5 0 0,0 5,15.5A2.5,2.5 0 0,0 7.5,18A2.5,2.5 0 0,0 10,15.5A2.5,2.5 0 0,0 7.5,13M16.5,13A2.5,2.5 0 0,0 14,15.5A2.5,2.5 0 0,0 16.5,18A2.5,2.5 0 0,0 19,15.5A2.5,2.5 0 0,0 16.5,13Z"
                        Foreground="{DynamicResource BrushIconMuted}" Width="16" Height="16"/>
              <TextBlock Text="Active Processes" Foreground="{DynamicResource BrushTextHeader}" FontSize="12"
                         FontWeight="SemiBold" VerticalAlignment="Center" Margin="8,0,0,0"/>
            </StackPanel>
            <TextBlock HorizontalAlignment="Right" VerticalAlignment="Center"
                       Foreground="{DynamicResource BrushTextSecondaryAlt}" FontSize="10">
              <Run Text="{Binding ProcessCount}"/>
              <Run Text=" processes"/>
            </TextBlock>
          </Grid>
        </Border>

        <Grid Grid.Row="1" RowDefinitions="Auto,*">
          <Grid ColumnDefinitions="3*,1.2*,1.2*,1.2*,1.2*" Margin="10,8,10,4">
            <Button Content="Name" Command="{Binding SortProcessesCommand}" CommandParameter="Name"
                    HorizontalAlignment="Left" Background="{DynamicResource BrushTransparent}" BorderThickness="0"
                    Foreground="{DynamicResource BrushTextHeader}" FontSize="10" FontWeight="SemiBold" Padding="0"/>
            <Button Grid.Column="1" Content="? Current" Command="{Binding SortProcessesCommand}" CommandParameter="CurrentDownload"
                    HorizontalAlignment="Left" Background="{DynamicResource BrushTransparent}" BorderThickness="0"
                    Foreground="{DynamicResource BrushTextHeader}" FontSize="10" FontWeight="SemiBold" Padding="0"/>
            <Button Grid.Column="2" Content="? Current" Command="{Binding SortProcessesCommand}" CommandParameter="CurrentUpload"
                    HorizontalAlignment="Left" Background="{DynamicResource BrushTransparent}" BorderThickness="0"
                    Foreground="{DynamicResource BrushTextHeader}" FontSize="10" FontWeight="SemiBold" Padding="0"/>
            <Button Grid.Column="3" Content="? Total" Command="{Binding SortProcessesCommand}" CommandParameter="TotalDownload"
                    HorizontalAlignment="Left" Background="{DynamicResource BrushTransparent}" BorderThickness="0"
                    Foreground="{DynamicResource BrushTextHeader}" FontSize="10" FontWeight="SemiBold" Padding="0"/>
            <Button Grid.Column="4" Content="? Total" Command="{Binding SortProcessesCommand}" CommandParameter="TotalUpload"
                    HorizontalAlignment="Left" Background="{DynamicResource BrushTransparent}" BorderThickness="0"
                    Foreground="{DynamicResource BrushTextHeader}" FontSize="10" FontWeight="SemiBold" Padding="0"/>
          </Grid>

          <ScrollViewer Grid.Row="1" Margin="0,0,0,6">
            <ItemsControl ItemsSource="{Binding ActiveProcesses}">
              <ItemsControl.ItemTemplate>
                <DataTemplate>
                  <Grid ColumnDefinitions="3*,1.2*,1.2*,1.2*,1.2*" Margin="10,4">
                    <Grid ColumnDefinitions="Auto,*" ColumnSpacing="8" MinWidth="0">
                      <Image Source="{Binding Icon}" Width="16" Height="16"/>
                      <TextBlock Grid.Column="1" Text="{Binding ProcessName}" Foreground="{DynamicResource BrushTextBody}"
                                 FontSize="11" TextWrapping="Wrap" MinWidth="0"/>
                    </Grid>
                    <TextBlock Grid.Column="1" Text="{Binding CurrentDownload}" Foreground="{DynamicResource BrushTextBody}" FontSize="11" VerticalAlignment="Top"/>
                    <TextBlock Grid.Column="2" Text="{Binding CurrentUpload}" Foreground="{DynamicResource BrushTextBody}" FontSize="11" VerticalAlignment="Top"/>
                    <TextBlock Grid.Column="3" Text="{Binding TotalDownload}" Foreground="{DynamicResource BrushTextBody}" FontSize="11" VerticalAlignment="Top"/>
                    <TextBlock Grid.Column="4" Text="{Binding TotalUpload}" Foreground="{DynamicResource BrushTextBody}" FontSize="11" VerticalAlignment="Top"/>
                  </Grid>
                </DataTemplate>
              </ItemsControl.ItemTemplate>
            </ItemsControl>
          </ScrollViewer>
        </Grid>
      </Grid>
    </Border>

    <Border Grid.Row="1" Grid.Column="0" Grid.ColumnSpan="3"
            Padding="10" CornerRadius="0,12,12,12" Background="{DynamicResource BrushSurfacePanel}"
            BoxShadow="{DynamicResource ShadowStrong}">
      <lvc:CartesianChart Series="{Binding GraphSeries}"
                          Background="{DynamicResource BrushGraphBackground}"
                          XAxes="{Binding GraphXAxes}"
                          YAxes="{Binding GraphYAxes}"
                          ZoomMode="None"
                          TooltipPosition="Hidden"
                          AnimationsSpeed="00:00:00.150"/>
    </Border>
  </Grid>
</UserControl>
