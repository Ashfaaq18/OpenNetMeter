<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:vm="clr-namespace:OpenNetMeter.ViewModels"
             xmlns:ctrl="using:OpenNetMeter.Views.Controls"
             x:Class="OpenNetMeter.Views.MainWindowTabs.HistoryView"
             x:DataType="vm:HistoryViewModel"
             mc:Ignorable="d">
  <Grid Margin="12,8" RowDefinitions="Auto,*,Auto">
    <Border Padding="12" CornerRadius="8" Background="{DynamicResource BrushSurfacePanel}">
      <StackPanel Orientation="Horizontal" Spacing="8" VerticalAlignment="Center" HorizontalAlignment="Center">
        <TextBlock VerticalAlignment="Center" Text="Usage of"/>
        <ComboBox Width="180"
                  ItemsSource="{Binding Profiles}"
                  SelectedItem="{Binding SelectedProfile, Mode=TwoWay}"/>
        <TextBlock VerticalAlignment="Center" Text="From"/>
        <DatePicker MinWidth="0" Width="140" Height="30" HorizontalAlignment="Stretch" VerticalAlignment="Center"
                    SelectedDate="{Binding DateStart, Mode=TwoWay}"/>
        <TextBlock VerticalAlignment="Center" Text="To"/>
        <DatePicker MinWidth="0" Width="140" Height="30" HorizontalAlignment="Stretch" VerticalAlignment="Center"
                    SelectedDate="{Binding DateEnd, Mode=TwoWay}"/>
        <Button Width="64" Height="24" Padding="0" Command="{Binding FilterCommand}">
          <TextBlock Text="Filter" VerticalAlignment="Center" HorizontalAlignment="Center"/>
        </Button>
      </StackPanel>
    </Border>

    <Border Grid.Row="1" Margin="0,12,0,12" Padding="0" CornerRadius="8" Background="{DynamicResource BrushSurfacePanel}" ClipToBounds="True">
      <Grid RowDefinitions="Auto,*">
        <Border Grid.Row="0" Padding="12,8" Background="{DynamicResource BrushHeaderRow}" BorderBrush="{DynamicResource BrushBorderEmphasis}" BorderThickness="0,0,0,0.4">
          <Grid ColumnDefinitions="3*,1.5*,1.5*">
            <StackPanel Orientation="Horizontal">
              <TextBlock Text="Process" Foreground="{DynamicResource BrushTextHeader}"
                         FontSize="10" FontWeight="SemiBold" VerticalAlignment="Center" Margin="0,0,4,0"/>
              <Button Command="{Binding SortRowsCommand}" CommandParameter="Process"
                      Background="{DynamicResource BrushHeaderRow}" BorderBrush="{DynamicResource BrushBorderEmphasis}"
                      BorderThickness="1" CornerRadius="4" Padding="4,2">
                <ctrl:SortIndicatorControl ColumnName="Process"
                                           CurrentSortColumn="{Binding CurrentSortColumn}"
                                           IsSortDescending="{Binding IsSortDescending}"/>
              </Button>
            </StackPanel>

            <StackPanel Grid.Column="1" Orientation="Horizontal">
              <TextBlock Text="Data Received" Foreground="{DynamicResource BrushTextHeader}"
                         FontSize="10" FontWeight="SemiBold" VerticalAlignment="Center" Margin="0,0,4,0"/>
              <Button Command="{Binding SortRowsCommand}" CommandParameter="Download"
                      Background="{DynamicResource BrushHeaderRow}" BorderBrush="{DynamicResource BrushBorderEmphasis}"
                      BorderThickness="1" CornerRadius="4" Padding="4,2">
                <ctrl:SortIndicatorControl ColumnName="Download"
                                           CurrentSortColumn="{Binding CurrentSortColumn}"
                                           IsSortDescending="{Binding IsSortDescending}"/>
              </Button>
            </StackPanel>

            <StackPanel Grid.Column="2" Orientation="Horizontal">
              <TextBlock Text="Data Sent" Foreground="{DynamicResource BrushTextHeader}"
                         FontSize="10" FontWeight="SemiBold" VerticalAlignment="Center" Margin="0,0,4,0"/>
              <Button Command="{Binding SortRowsCommand}" CommandParameter="Upload"
                      Background="{DynamicResource BrushHeaderRow}" BorderBrush="{DynamicResource BrushBorderEmphasis}"
                      BorderThickness="1" CornerRadius="4" Padding="4,2">
                <ctrl:SortIndicatorControl ColumnName="Upload"
                                           CurrentSortColumn="{Binding CurrentSortColumn}"
                                           IsSortDescending="{Binding IsSortDescending}"/>
              </Button>
            </StackPanel>
          </Grid>
        </Border>

        <ScrollViewer Grid.Row="1" Margin="0,0,0,6">
          <ItemsControl ItemsSource="{Binding Rows}">
            <ItemsControl.ItemTemplate>
              <DataTemplate>
                <Grid ColumnDefinitions="3*,1.5*,1.5*" Margin="10,4">
                  <StackPanel Orientation="Horizontal" Spacing="4" MinWidth="0">
                    <Button Command="{Binding SearchProcessCommand}"
                            Background="Transparent" BorderThickness="0"
                            Padding="2" Cursor="Hand"
                            ToolTip.Tip="Search online">
                      <PathIcon Data="M9.5,3A6.5,6.5 0 0,1 16,9.5C16,11.11 15.41,12.59 14.44,13.73L14.71,14H15.5L20.5,19L19,20.5L14,15.5V14.71L13.73,14.44C12.59,15.41 11.11,16 9.5,16A6.5,6.5 0 0,1 3,9.5A6.5,6.5 0 0,1 9.5,3M9.5,5C7,5 5,7 5,9.5C5,12 7,14 9.5,14C12,14 14,12 14,9.5C14,7 12,5 9.5,5Z"
                              Width="12" Height="12"
                              Foreground="{DynamicResource BrushTextSecondary}"/>
                    </Button>
                    <Image Source="{Binding Icon}" Width="16" Height="16"/>
                    <TextBlock Text="{Binding ProcessName}" Foreground="{DynamicResource BrushTextBody}" FontSize="11"
                               TextWrapping="Wrap" MinWidth="0" VerticalAlignment="Center"/>
                  </StackPanel>
                  <TextBlock Grid.Column="1" Text="{Binding DownloadText}" Foreground="{DynamicResource BrushTextBody}" FontSize="11" VerticalAlignment="Top"/>
                  <TextBlock Grid.Column="2" Text="{Binding UploadText}" Foreground="{DynamicResource BrushTextBody}" FontSize="11" VerticalAlignment="Top"/>
                </Grid>
              </DataTemplate>
            </ItemsControl.ItemTemplate>
          </ItemsControl>
        </ScrollViewer>
      </Grid>
    </Border>

    <Border Grid.Row="2" Padding="12" CornerRadius="8" Background="{DynamicResource BrushSurfacePanel}">
      <Grid ColumnDefinitions="2*,*,*">
        <TextBlock FontWeight="SemiBold" Text="Total"/>
        <TextBlock Grid.Column="1" Text="{Binding TotalDownloadText}"/>
        <TextBlock Grid.Column="2" Text="{Binding TotalUploadText}"/>
      </Grid>
    </Border>
  </Grid>
</UserControl>
