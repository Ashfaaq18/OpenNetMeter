<ResourceDictionary xmlns="https://github.com/avaloniaui"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
  <ResourceDictionary.ThemeDictionaries>
    <ResourceDictionary x:Key="Dark">
      <SolidColorBrush x:Key="BrushBgWindow" Color="#151515"/>
      <SolidColorBrush x:Key="BrushBgTitleBar" Color="#202020"/>
      <SolidColorBrush x:Key="BrushBgSurface" Color="#303030"/>
      <SolidColorBrush x:Key="BrushBgSurfaceHover" Color="#2A2A2A"/>
      <SolidColorBrush x:Key="BrushBgSubtle" Color="#252525"/>
      <SolidColorBrush x:Key="BrushBorderMain" Color="#616161"/>
      <SolidColorBrush x:Key="BrushBorderSubtle" Color="#555555"/>
      <SolidColorBrush x:Key="BrushTextPrimary" Color="#FFFFFF"/>
      <SolidColorBrush x:Key="BrushTextSecondary" Color="#A9ABAB"/>
      <SolidColorBrush x:Key="BrushSurfacePanel" Color="#303030"/>
      <SolidColorBrush x:Key="BrushPanelAlt" Color="#252525"/>
      <SolidColorBrush x:Key="BrushHeaderRow" Color="#2A2A2A"/>
      <SolidColorBrush x:Key="BrushDivider" Color="#555555"/>
      <SolidColorBrush x:Key="BrushBorderEmphasis" Color="#616161"/>
      <SolidColorBrush x:Key="BrushTextUi" Color="#F0F0F0"/>
      <SolidColorBrush x:Key="BrushTextBody" Color="#F0F0F0"/>
      <SolidColorBrush x:Key="BrushTextMuted" Color="#A9ABAB"/>
      <SolidColorBrush x:Key="BrushTextFaint" Color="#6B7280"/>
      <SolidColorBrush x:Key="BrushTextHeader" Color="#F0F0F0"/>
      <SolidColorBrush x:Key="BrushTabActiveText" Color="#FFFFFF"/>
      <SolidColorBrush x:Key="BrushIconMuted" Color="#A9ABAB"/>
      <SolidColorBrush x:Key="BrushTextSecondaryAlt" Color="#A9ABAB"/>
      <SolidColorBrush x:Key="BrushDangerBorderSoft" Color="#3D2020"/>
      <SolidColorBrush x:Key="BrushDangerBgSoft" Color="#1A1215"/>
      <SolidColorBrush x:Key="BrushPillCheckedBg" Color="#1A3A5C"/>
      <SolidColorBrush x:Key="BrushGraphBackground" Color="#252525"/>
      <SolidColorBrush x:Key="BrushLink" Color="#5FA8FF"/>
      <SolidColorBrush x:Key="BrushShadowStrong" Color="#33000000"/>
      <SolidColorBrush x:Key="BrushShadowSoft" Color="#20000000"/>
      <SolidColorBrush x:Key="BrushAccentGreen" Color="#367061"/>
      <SolidColorBrush x:Key="BrushAccentBlue" Color="#00A6A0"/>
      <SolidColorBrush x:Key="BrushSuccess" Color="#367061"/>
      <SolidColorBrush x:Key="BrushInfo" Color="#D98868"/>
      <SolidColorBrush x:Key="BrushWarning" Color="#FFA37E"/>
      <SolidColorBrush x:Key="BrushAccentPurple" Color="#8957E5"/>
      <SolidColorBrush x:Key="BrushDangerBright" Color="#E81123"/>
      <BoxShadows x:Key="ShadowStrong">0 2 10 0 #33000000</BoxShadows>
      <BoxShadows x:Key="ShadowSoft">0 1 4 0 #20000000</BoxShadows>
    </ResourceDictionary>
    <ResourceDictionary x:Key="Light">
      <SolidColorBrush x:Key="BrushBgWindow" Color="#eeeeee"/>
      <SolidColorBrush x:Key="BrushBgTitleBar" Color="#FFFFFF"/>
      <SolidColorBrush x:Key="BrushBgSurface" Color="#FFFFFF"/>
      <SolidColorBrush x:Key="BrushBgSurfaceHover" Color="#F9FAFB"/>
      <SolidColorBrush x:Key="BrushBgSubtle" Color="#F8F8F8"/>
      <SolidColorBrush x:Key="BrushBorderMain" Color="#4F5050"/>
      <SolidColorBrush x:Key="BrushBorderSubtle" Color="#E5E7EB"/>
      <SolidColorBrush x:Key="BrushTextPrimary" Color="#000000"/>
      <SolidColorBrush x:Key="BrushTextSecondary" Color="#666666"/>
      <SolidColorBrush x:Key="BrushSurfacePanel" Color="#FFFFFF"/>
      <SolidColorBrush x:Key="BrushPanelAlt" Color="#d8d8d8"/>
      <SolidColorBrush x:Key="BrushHeaderRow" Color="#d6d6d6"/>
      <SolidColorBrush x:Key="BrushDivider" Color="#E5E7EB"/>
      <SolidColorBrush x:Key="BrushBorderEmphasis" Color="#888888"/>
      <SolidColorBrush x:Key="BrushTextUi" Color="#000000"/>
      <SolidColorBrush x:Key="BrushTextBody" Color="#1F2937"/>
      <SolidColorBrush x:Key="BrushTextMuted" Color="#6B7280"/>
      <SolidColorBrush x:Key="BrushTextFaint" Color="#AAAAAA"/>
      <SolidColorBrush x:Key="BrushTextHeader" Color="#1A1A1A"/>
      <SolidColorBrush x:Key="BrushTabActiveText" Color="#000000"/>
      <SolidColorBrush x:Key="BrushIconMuted" Color="#6B7280"/>
      <SolidColorBrush x:Key="BrushTextSecondaryAlt" Color="#4F5050"/>
      <SolidColorBrush x:Key="BrushDangerBorderSoft" Color="#E5BABA"/>
      <SolidColorBrush x:Key="BrushDangerBgSoft" Color="#FCEDED"/>
      <SolidColorBrush x:Key="BrushPillCheckedBg" Color="#F0FDFA"/>
      <SolidColorBrush x:Key="BrushGraphBackground" Color="#FFFFFF"/>
      <SolidColorBrush x:Key="BrushLink" Color="#4287F5"/>
      <SolidColorBrush x:Key="BrushShadowStrong" Color="#1ADDDDDD"/>
      <SolidColorBrush x:Key="BrushShadowSoft" Color="#14000000"/>
      <SolidColorBrush x:Key="BrushAccentGreen" Color="#7FB6A8"/>
      <SolidColorBrush x:Key="BrushAccentBlue" Color="#00A6A0"/>
      <SolidColorBrush x:Key="BrushSuccess" Color="#6DA395"/>
      <SolidColorBrush x:Key="BrushInfo" Color="#C97C5D"/>
      <SolidColorBrush x:Key="BrushWarning" Color="#FFA37E"/>
      <SolidColorBrush x:Key="BrushAccentPurple" Color="#8957E5"/>
      <SolidColorBrush x:Key="BrushDangerBright" Color="#E81123"/>
      <BoxShadows x:Key="ShadowStrong">0 2 10 0 #1ADDDDDD</BoxShadows>
      <BoxShadows x:Key="ShadowSoft">0 1 4 0 #14000000</BoxShadows>
    </ResourceDictionary>
  </ResourceDictionary.ThemeDictionaries>

  <SolidColorBrush x:Key="BrushTransparent" Color="Transparent"/>
  <SolidColorBrush x:Key="BrushWhite" Color="#FFFFFF"/>
  <SolidColorBrush x:Key="BrushDanger" Color="#E81123"/>
  <SolidColorBrush x:Key="BrushOverlayScrim" Color="#A0000000"/>

  <x:Double x:Key="FontSizeXs">10</x:Double>
  <x:Double x:Key="FontSizeSm">11</x:Double>
  <x:Double x:Key="FontSizeMd">12</x:Double>
  <x:Double x:Key="FontSizeLg">13</x:Double>
</ResourceDictionary>
