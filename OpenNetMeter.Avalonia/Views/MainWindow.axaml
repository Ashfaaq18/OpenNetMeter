<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:vm="clr-namespace:OpenNetMeter.Avalonia.ViewModels"
        x:Class="OpenNetMeter.Avalonia.Views.MainWindow"
        x:DataType="vm:MainWindowViewModel"
        Width="900"
        Height="600"
        MinWidth="800"
        MinHeight="500"
        Title="OpenNetMeter (Avalonia)">
  <Design.DataContext>
    <vm:MainWindowViewModel/>
  </Design.DataContext>

  <Grid RowDefinitions="Auto,*" Margin="16">
    <TextBlock FontSize="20" FontWeight="SemiBold" Text="OpenNetMeter Avalonia"/>
    <TabControl Grid.Row="1"
                Margin="0,12,0,0"
                SelectedIndex="{Binding SelectedTabIndex, Mode=TwoWay}">
      <TabItem Header="Summary">
        <Border Margin="8" Padding="12" CornerRadius="8" Background="#1E3A5F">
          <TextBlock Foreground="White"
                     TextWrapping="Wrap"
                     Text="Summary tab shell is wired to shared tab-state view model."/>
        </Border>
      </TabItem>
      <TabItem Header="History">
        <Border Margin="8" Padding="12" CornerRadius="8" Background="#2E4A2A">
          <TextBlock Foreground="White"
                     TextWrapping="Wrap"
                     Text="History tab shell is active. Content port comes in next phases."/>
        </Border>
      </TabItem>
      <TabItem Header="Settings">
        <Border Margin="8" Padding="12" CornerRadius="8" Background="#5A3A1E">
          <TextBlock Foreground="White"
                     TextWrapping="Wrap"
                     Text="Settings tab shell is active. Full settings view port is Phase 9."/>
        </Border>
      </TabItem>
    </TabControl>
  </Grid>
</Window>
